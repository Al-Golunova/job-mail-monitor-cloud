GMX_EMAIL=your_name@gmx.de
GMX_PASSWORD=your_gmx_password_or_app_password
IMAP_HOST=imap.gmx.com
IMAP_PORT=993
MAILBOX=INBOX
SCAN_DAYS=14
MAX_MESSAGES_PER_RUN=200

GOOGLE_SHEET_ID=your_google_sheet_id
JOBS_WORKSHEET=jobs
EVENTS_WORKSHEET=mail_events

# Option A: paste the full service account JSON as one line into GitHub Secret / env
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B: use a local file when testing on your computer
GOOGLE_SERVICE_ACCOUNT_FILE=

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456:ABCDEF...
TELEGRAM_CHAT_ID=123456789
NOTIFY_ON=interview,documents,offer

DRY_RUN=false
